# --- Option A: Docker Mongo (default with docker compose) ---
# Leave MONGO_URI unset, or use host "mongodb" (NOT localhost inside containers):
# USER_MONGO_URI=mongodb://mongodb:27017/user_service
# UPLOAD_MONGO_URI=mongodb://mongodb:27017/upload_service
# WATCH_MONGO_URI=mongodb://mongodb:27017/watch_service

# --- Option B: MongoDB Atlas (all services) ---
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
# Or per-service with different DB names:
# USER_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/user_service
# UPLOAD_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/upload_service
# WATCH_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/watch_service

JWT_SECRET=replace-with-a-long-random-secret

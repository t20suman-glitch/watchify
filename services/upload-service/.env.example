MONGO_URI=mongodb://localhost:27017/upload_service
PORT=50052
HTTP_PORT=3002
STORAGE_PROVIDER=s3
MAX_FILE_SIZE_MB=500

# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket

# Optional — VPC Interface endpoint without Private DNS only
# AWS_S3_ENDPOINT_URL=https://vpce-xxx.s3.us-east-1.vpce.amazonaws.com
# AWS_S3_FORCE_PATH_STYLE=true

# Optional — omit on EKS when using IRSA / on EC2 with instance profile
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Local disk fallback (STORAGE_PROVIDER=local)
# UPLOAD_DIR=./uploads

# Logging (optional)
# NODE_ENV=production
# LOG_LEVEL=info

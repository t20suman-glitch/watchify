{
  "name": "upload-service",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "docker:build": "docker build -t upload-service .",
    "docker:run": "docker run --rm -p 50052:50052 -p 3002:3002 -v \"%cd%/uploads:/app/uploads\" --env-file .env upload-service"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=18"
  }
}

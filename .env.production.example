# Copy to .env on your EC2 instance before starting the stack:
#   cp .env.production.example .env

# Required — use a long random string (same value for user + watch services)
JWT_SECRET=replace-with-a-long-random-secret

# Optional
JWT_EXPIRES_IN=7d
LOG_LEVEL=info
FRONTEND_PORT=80
UPLOAD_PORT=3002
MAX_FILE_SIZE_MB=500
STORAGE_PROVIDER=local

# --- Built-in Mongo (default) — leave unset to use the mongodb container ---
# USER_MONGO_URI=mongodb://mongodb:27017/user_service
# UPLOAD_MONGO_URI=mongodb://mongodb:27017/upload_service
# WATCH_MONGO_URI=mongodb://mongodb:27017/watch_service

# --- MongoDB Atlas (optional) ---
# USER_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/user_service
# UPLOAD_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/upload_service
# WATCH_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/watch_service

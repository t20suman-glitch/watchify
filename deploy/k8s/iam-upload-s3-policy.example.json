{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WatchifyUploadObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_YOUR_BUCKET/*"
    },
    {
      "Sid": "WatchifyUploadListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::REPLACE_WITH_YOUR_BUCKET"
    }
  ]
}

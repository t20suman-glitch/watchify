# Local development only (npm run dev on your machine).
# Copy to .env.local — this file is NOT used in Docker.
#
# Docker production uses docker-compose.prod.yml instead:
#   USER_SERVICE_URL=http://user-service:3001
#   UPLOAD_SERVICE_URL=http://upload-service:3002
#   WATCH_SERVICE_URL=http://watch-service:3003

USER_SERVICE_URL=http://localhost:3001
UPLOAD_SERVICE_URL=http://localhost:3002
WATCH_SERVICE_URL=http://localhost:3003
